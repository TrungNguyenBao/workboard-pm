    @model_validator(mode="before")
    @classmethod
    def extract_from_orm(cls, data: Any) -> Any:
        if isinstance(data, dict):
            return data
        # Read from already-loaded __dict__ to avoid triggering lazy loads
        d = data.__dict__
        assignee = d.get("assignee")
