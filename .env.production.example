# Environment Variables cho Production (Dokploy)
# Copy file này và điền giá trị thực trước khi deploy

# ─── Database (Postgres) ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://workboard:StrongPassword123@postgres:5432/workboard
POSTGRES_DB=workboard
POSTGRES_USER=workboard
POSTGRES_PASSWORD=StrongPassword123

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── JWT / Security ─────────────────────────────────────────────────────────
# Tạo bằng: openssl rand -hex 32
SECRET_KEY=replace-with-random-64-char-hex-string-generated-by-openssl

# ─── CORS / Frontend URL ─────────────────────────────────────────────────────
# Thay bằng domain thực của bạn (không có dấu / ở cuối)
FRONTEND_URL=https://your-domain.com
CORS_ORIGINS=["https://your-domain.com"]

# ─── Backend Performance ─────────────────────────────────────────────────────
WEB_CONCURRENCY=4
LOG_LEVEL=INFO

# ─── File Uploads ────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
