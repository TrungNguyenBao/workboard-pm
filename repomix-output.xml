        condition: service_healthy
      redis:
        condition: service_healthy
    restart: unless-stopped
    # No ports exposed — nginx proxies to backend internally

  nginx:
    build:
      context: .
      dockerfile: nginx/Dockerfile
    ports:
      - "80:80"
    depends_on:
      - backend
    restart: unless-stopped

  postgres:
    image: postgres:15-alpine
    environment:
      POSTGRES_DB: ${POSTGRES_DB:-workboard}
